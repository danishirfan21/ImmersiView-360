{
  "version": 2,
  "functions": {
    "server/index.cjs": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/index.cjs"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "/server/index.cjs"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
